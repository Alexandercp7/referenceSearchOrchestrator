# development | production
NODE_ENV=development

PORT=3000

# REQUIRED in production — app throws on startup if missing
JWT_SECRET=change-me-in-production

# Defaults apply when not set
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# In production defaults to 12 when not set; in development defaults to 10
BCRYPT_ROUNDS=10

SCHEDULER_INTERVAL_MS=60000
CACHE_TTL_SECONDS=300

# SMTP — omitir para usar solo console.log en desarrollo
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu@gmail.com
SMTP_PASS=app-password-aqui
SMTP_FROM=Reference <tu@gmail.com>

# Web Push VAPID — generar con: node -e "require('web-push').generateVAPIDKeys()"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tu@gmail.com
